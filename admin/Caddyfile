http://dozzle.localhost:3000 {
    reverse_proxy dozzle:8080
}

http://*:3000 {
    handle /dozzle {
        reverse_proxy dozzle:8080
    }

    handle /api/v1* {
        reverse_proxy service-dwb-admin:3000
    }

    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
