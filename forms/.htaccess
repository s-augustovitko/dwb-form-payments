# Enable rewrite engine
RewriteEngine On

# Route /api requests to /api (pass through)
RewriteRule ^api(?:/(.*))?$ api/$1 [L,END]

# Allow direct access to /web files (no rewrite)
RewriteRule ^web/ - [L,END]

# Root "/" → SPA entry
RewriteRule ^$ web/index.html [L,END]

# If file exists in /web
RewriteCond %{DOCUMENT_ROOT}/web/$1 -f [OR]

# Or directory exists in /web
RewriteCond %{DOCUMENT_ROOT}/web/$1 -d

# Serve existing file/dir from /web
RewriteRule ^(.*)$ web/$1 [L,END]

# Fallback → SPA (client-side routing)
RewriteRule ^.*$ web/index.html [L,END]

